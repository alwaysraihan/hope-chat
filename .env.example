# Optional overrides — `.env` is gitignored.
# Production release APK/IPA defaults to https://livekit.hopenity.com + wss when these are omitted.

#LIVEKIT_TOKEN_SERVICE_URL=https://livekit.hopenity.com

# Only when VPS TOKEN_ISSUER_SECRET is set.
#LIVEKIT_ISSUER_SECRET=

# Local dev overrides (Metro):
#LIVEKIT_WS_URL=ws://192.168.1.50:7880

# Dev bypass — fixed JWT from livekit-cli instead of POST mint.
#LIVEKIT_DEV_TOKEN=
