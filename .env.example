# Copy to `.env` at the project root and adjust. Restart Metro (`npx react-native start`) after changes.

# Hopenity REST API
API_BASE_URL=https://api.hopenity.com

# LiveKit — same host as your token mint + signaling in production
LIVEKIT_URL=https://livekit.hopenity.com

# Optional: usually same as LIVEKIT_URL
LIVEKIT_TOKEN_SERVICE_URL=

# REST credentials (prefer server-only; app may only need mint secret below)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Maps to X-Hopechat-LiveKit-Secret for POST /v1/livekit/token (match VPS TOKEN_ISSUER_SECRET).
# Leave blank to reuse LIVEKIT_API_SECRET.
LIVEKIT_ISSUER_SECRET=

# Leave empty to derive wss:// from LIVEKIT_URL. For LAN LiveKit: ws://192.168.x.x:7880
LIVEKIT_WS_URL=

# Dev only: paste a JWT from livekit-cli instead of minting (leave empty for normal use)
LIVEKIT_DEV_TOKEN=

# Android only: set true to publish camera on LiveKit connect (default off — some devices crash native WebRTC)
LIVEKIT_ANDROID_PUBLISH_VIDEO=
